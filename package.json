{
  "scripts": {
    "start": "npm run start:backend",
    "start:backend": "cd backend && node index.js",
    "start:pairwise": "cd backend-pairwise && node server.js",
    "start:inference": "cd backend-pairwise/python && python inference_server_dinov2.py",
    "start:binary": "cd backend-pairwise/python && python inference_binary.py",
    "full": "npx concurrently \"npm run start:backend\" \"npm run start:pairwise\" \"npm run start:inference\" \"npm run start:binary\"",
    "build": "cd frontend && npm run build",
    "kill": "taskkill /f /im node.exe && taskkill /f /im python.exe"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.2.0",
    "chokidar": "^4.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fs-extra": "^11.3.0",
    "multer": "^2.0.1",
    "open": "^10.2.0",
    "puppeteer-core": "^24.23.0",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "video-thumbnail-generator": "^1.1.3",
    "ws": "^8.18.3"
  }
}